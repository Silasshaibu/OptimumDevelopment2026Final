                        <img src="assets/CountriesFlag/united-states.svg" alt="US Flag" width="24" height="16">
                        <span>English (US)</span>
                    </div>
                    <div class="lang-option"
                        onclick="selectLang('assets/CountriesFlag/united-kingdom.svg', 'English (UK)', event)">
                        <img src="assets/CountriesFlag/united-kingdom.svg" alt="UK Flag" width="24" height="16">
                        <span>English (UK)</span>
                    </div>
                    <div class="lang-option" onclick="selectLang('assets/CountriesFlag/spain.svg', 'Español', event)">
                        <img src="assets/CountriesFlag/spain.svg" alt="Spain Flag" width="24" height="16">
                        <span>Español</span>
                    </div>
                </div>
            </div>
        </div>
